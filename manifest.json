{
  "manifest_version": 3,
  "name": "LaraCaption",
  "description": "Synced subtitles, AI translation (dual subtitles), study mode and an AI chat tutor for Laracasts lessons.",
  "version": "0.1.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "LaraCaption",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://laracasts.com/*",
        "https://www.laracasts.com/*"
      ],
      "js": [
        "src/inject.js"
      ],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://laracasts.com/*",
        "https://www.laracasts.com/*"
      ],
      "js": [
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://laracasts.com/*",
    "https://www.laracasts.com/*",
    "https://player.vimeo.com/*",
    "https://*.vimeo.com/*",
    "https://*.vimeocdn.com/*",
    "https://*.mux.com/*",
    "https://api.openai.com/*"
  ]
}
